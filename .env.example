# Supabase (Settings -> API jūsų Supabase projekte)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Slaptažodis, kuriuo prisijungiate prie website'o
ADMIN_PASSWORD=pasirinkite_stiprų_slaptažodį

# SMTP siuntimui (žr. README.md dėl Gmail/Workspace arba hostingo pašto nustatymų)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@lumera.lt
SMTP_PASS=app_password_arba_pašto_slaptažodis
SMTP_FROM=info@lumera.lt
